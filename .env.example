# 사이트 기본 URL (배포 후 실제 도메인으로 변경. sitemap.xml, OG태그, robots.txt 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://grace-news.vercel.app

# 사이트명
NEXT_PUBLIC_SITE_NAME=은혜뉴스

# 구글 애드센스 발급 후 client ID (형식: ca-pub-xxxxxxxxxxxxxxxx)
# 심사 통과 전에는 비워둬도 사이트는 정상 동작합니다 (광고 영역에 안내 박스만 표시됨)
NEXT_PUBLIC_ADSENSE_CLIENT=

# (선택) 각 광고 슬롯 ID. 애드센스에서 광고 단위를 만들면 발급됩니다.
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=

# (선택) Anthropic API 키를 넣으면 Claude가 기사 3줄 요약을 생성합니다.
# 비워두면 자동으로 "본문 앞부분 발췌" 방식의 무료 요약으로 대체됩니다.
ANTHROPIC_API_KEY=

# (선택) 구글 서치 콘솔 소유권 확인용 meta 태그 값 (HTML 태그 방식 인증 시)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# (선택) 네이버 서치어드바이저 소유권 확인용 meta 태그 값
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# 문의 페이지에 표시될 연락용 이메일
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
